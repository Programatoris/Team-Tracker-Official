<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SessionActivity">

    <!-- LEFT PANEL -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/leftPanel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="#354e46"
        android:padding="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/rightPanel"
        app:layout_constraintWidth_percent="0.35">

        <!-- subtle grid overlay -->
        <View
            android:id="@+id/leftGrid"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="0.10"
            android:background="@drawable/bg_grid_overlay"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvTeam"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:letterSpacing="0.02"
            android:text="Team selection"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- small subtitle (optional but helps fill space) -->
        <TextView
            android:id="@+id/tvTeamSub"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Join an existing session or host a new one."
            android:textAlignment="center"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTeam" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnJoin"
            android:layout_width="184dp"
            android:layout_height="46dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="#F5A623"
            android:text="Join"
            android:textAllCaps="false"
            android:textColor="#1E1E1E"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTeamSub" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHost"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:text="Host"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:backgroundTint="#F5A623"
            android:textColor="#1E1E1E"
            app:cornerRadius="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnJoin"
            app:layout_constraintStart_toStartOf="@id/btnJoin"
            app:layout_constraintEnd_toEndOf="@id/btnJoin"/>

        <!-- bottom helper text to balance the panel -->
        <TextView
            android:id="@+id/tvHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tip: Hosting creates a Session ID you can share."
            android:textAlignment="center"
            android:textColor="#99FFFFFF"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RIGHT PANEL -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rightPanel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="#8aa494"
        android:padding="24dp"
        app:layout_constraintStart_toEndOf="@id/leftPanel"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- soft card behind inputs -->
        <androidx.cardview.widget.CardView
            android:id="@+id/inputCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#33FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edittext_rounded_white"
                    android:hint="Name"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#1E1E1E"
                    android:textColorHint="#7A7A7A"
                    android:inputType="textPersonName"/>

                <EditText
                    android:id="@+id/etSession"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/edittext_rounded_white"
                    android:hint="Session ID"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#1E1E1E"
                    android:textColorHint="#7A7A7A"
                    android:inputType="text"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- optional faint grid on right too -->
        <View
            android:id="@+id/rightGrid"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="0.06"
            android:background="@drawable/bg_grid_overlay"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
