<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAP -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- EYE stays visible -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/eyeChip"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="false"
        app:cardPreventCornerOverlap="true"
        app:cardBackgroundColor="#354e46"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnEye"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:contentDescription="@string/eye"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_eye" />
    </com.google.android.material.card.MaterialCardView>

    <!-- EVERYTHING that should hide goes in here -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/overlayUi"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- MENU -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuChip"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            app:cardUseCompatPadding="false"
            app:cardPreventCornerOverlap="true"
            app:cardBackgroundColor="#354e46"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:contentDescription="@string/menu"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_menu" />
        </com.google.android.material.card.MaterialCardView>

        <!-- LEFT TOOLBAR -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/leftToolbarCard"
            android:layout_width="64dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="28dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="false"
            app:cardPreventCornerOverlap="true"
            app:cardBackgroundColor="#354e46"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:id="@+id/leftToolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="10dp">

                <ImageButton
                    android:id="@+id/btnCenterMap"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/center_map"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_my_location" />

                <View
                    android:layout_width="28dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:alpha="0.25"
                    android:background="#FFFFFF" />

                <ImageButton
                    android:id="@+id/btnPlusPins"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/add_pin"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_plus_circle" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- PIN PICKER (not full width anymore) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/pinPickerCard"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="18dp"
            app:cardElevation="12dp"
            app:cardUseCompatPadding="false"
            app:cardPreventCornerOverlap="true"
            app:cardBackgroundColor="#3F5B52"
            app:layout_constraintStart_toEndOf="@id/leftToolbarCard"
            app:layout_constraintBottom_toBottomOf="@id/leftToolbarCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/pinPickerTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add a pin"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:alpha="0.95" />

                <Space
                    android:layout_width="1dp"
                    android:layout_height="10dp" />

                <androidx.gridlayout.widget.GridLayout
                    android:id="@+id/pinPickerGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:columnCount="6"
                    app:rowCount="1">

                    <ImageButton
                        android:id="@+id/pinHouse"
                        style="@style/PinChoiceButton"
                        android:src="@drawable/ic_pin_house" />

                    <ImageButton
                        android:id="@+id/pinFlag"
                        style="@style/PinChoiceButton"
                        android:src="@drawable/ic_pin_flag" />

                    <ImageButton
                        android:id="@+id/pinStar"
                        style="@style/PinChoiceButton"
                        android:src="@drawable/ic_pin_star" />

                    <ImageButton
                        android:id="@+id/pinSkull"
                        style="@style/PinChoiceButton"
                        android:src="@drawable/ic_pin_skull" />

                    <ImageButton
                        android:id="@+id/pinTarget"
                        style="@style/PinChoiceButton"
                        android:src="@drawable/ic_pin_target" />

                    <ImageButton
                        android:id="@+id/pinPlus"
                        style="@style/PinChoiceButton"
                        android:src="@drawable/ic_pin_plus" />
                </androidx.gridlayout.widget.GridLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SESSION CARD (below menu) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sessionCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="false"
            app:cardPreventCornerOverlap="true"
            app:cardBackgroundColor="#3F5B52"
            app:layout_constraintTop_toBottomOf="@id/menuChip"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/txtSessionId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Session ID: 52s16a87v"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:alpha="0.95" />

                <Space
                    android:layout_width="1dp"
                    android:layout_height="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLeave"
                    android:layout_width="240dp"
                    android:layout_height="42dp"
                    android:backgroundTint="#D62828"
                    android:text="Leave"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="14dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
